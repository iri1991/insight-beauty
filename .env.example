MONGODB_URI=mongodb://127.0.0.1:27017/beautyapp
MONGODB_DB=beautyapp

# Email tranzactional (SMTP — optional, fallback la console.log daca nu e configurat)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@insightbeauty.ro
SMTP_PASS=parola_smtp
EMAIL_FROM_NAME=Insight Beauty
EMAIL_FROM_ADDRESS=noreply@insightbeauty.ro

# PWA / Push Notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@insightbeauty.local
